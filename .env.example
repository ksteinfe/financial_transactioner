# Global repository paths for local data (used by tools/ and apps/)
# Copy this file to .env and adjust to your machine.

# Directory containing local JSON corpus files
TRANSACTION_CORPUS_DIR=/absolute/path/to/local/transaction-corpus

# Directory containing newly downloaded transaction CSV files awaiting processing
TRANSACTION_DOWNLOADS_UNPROCESSED_DIR=/absolute/path/to/local/transactions/unprocessed

# Directory where normalized/processed CSV files are written
TRANSACTION_DOWNLOADS_PROCESSED_DIR=/absolute/path/to/local/transactions/processed
